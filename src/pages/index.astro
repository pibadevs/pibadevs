---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
---

<BaseLayout
  title="PibaDevs · Software a medida para PYMES"
  description="Diseñamos sistemas web que reemplazan Excel, chats y procesos manuales."
>
  <!-- HERO -->
  <Hero
    title="Llevamos tu operación más allá."
    subtitle="Diseñamos sistemas web a medida para que tu empresa deje atrás Excel, tenga datos confiables y procesos que realmente funcionen."
    tagline="Estudio de desarrollo a medida"
  />

  <!-- SERVICIOS -->
  <Section title="Qué hacemos" eyebrow="Servicios clave">
    <div class="flex flex-col divide-y" style="border-color: var(--color-divider);">
      
      <!-- ITEM -->
      <div class="grid grid-cols-[52px_1fr_auto] gap-4 py-6 reveal">
        <span class="text-sm font-semibold" style="color: var(--color-primary);">01</span>
        
        <div>
          <h3 class="text-base font-semibold mb-1">Sistemas web para operación diaria</h3>
          <p class="text-base" style="color: var(--color-text-muted);">
            Aplicaciones a medida para ventas, inventarios, reservas y atención al cliente, alineadas a cómo trabaja tu equipo.
          </p>
        </div>

        <span class="text-xs" style="color: var(--color-text-faint);">→</span>
      </div>

      <!-- ITEM -->
      <div class="grid grid-cols-[52px_1fr_auto] gap-4 py-6 reveal">
        <span class="text-sm font-semibold" style="color: var(--color-primary);">02</span>
        
        <div>
          <h3 class="text-base font-semibold mb-1">Automatización de procesos</h3>
          <p class="text-base" style="color: var(--color-text-muted);">
            Eliminamos Excel, chats y notas sueltas con sistemas centralizados, trazables y accesibles para todo tu equipo.
          </p>
        </div>

        <span class="text-xs" style="color: var(--color-text-faint);">→</span>
      </div>

      <!-- ITEM -->
      <div class="grid grid-cols-[52px_1fr_auto] gap-4 py-6 reveal">
        <span class="text-sm font-semibold" style="color: var(--color-primary);">03</span>
        
        <div>
          <h3 class="text-base font-semibold mb-1">Métricas y decisiones claras</h3>
          <p class="text-base" style="color: var(--color-text-muted);">
            Dashboards y reportes con las métricas que realmente importan: ventas, tiempos, capacidad y rendimiento.
          </p>
        </div>

        <span class="text-xs" style="color: var(--color-text-faint);">→</span>
      </div>

    </div>
  </Section>

  <!-- VALOR -->
  <Section title="Por qué PibaDevs" eyebrow="Valor real">
    <div class="grid gap-6 md:grid-cols-3">

      <div class="p-5 rounded-xl border reveal transition"
           style="border-color: var(--color-border); background: var(--color-surface);">
        <h3 class="font-semibold mb-2">Encaja con tu negocio</h3>
        <p class="text-base" style="color: var(--color-text-muted);">
          Diseñamos el sistema alrededor de tu operación real, no al revés.
        </p>
      </div>

      <div class="p-5 rounded-xl border reveal transition"
           style="border-color: var(--color-border); background: var(--color-surface);">
        <h3 class="font-semibold mb-2">Acompañamiento completo</h3>
        <p class="text-base" style="color: var(--color-text-muted);">
          Te guiamos desde la idea hasta la implementación y adopción.
        </p>
      </div>

      <div class="p-5 rounded-xl border reveal transition"
           style="border-color: var(--color-border); background: var(--color-surface);">
        <h3 class="font-semibold mb-2">Evolución constante</h3>
        <p class="text-base" style="color: var(--color-text-muted);">
          Mejoramos el sistema con base en datos y feedback real de uso.
        </p>
      </div>

    </div>
  </Section>

  <!-- CTA -->
  <Section title="¿Listo para mejorar tu operación?" eyebrow="Siguiente paso">
    <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between reveal">
      
      <p class="text-base max-w-xl" style="color: var(--color-text-muted);">
        Si tu empresa aún depende de Excel y procesos manuales, podemos ayudarte a construir un sistema propio que escale contigo.
      </p>

      <div class="flex gap-3">
        <a
          href="/projects"
          class="px-5 py-2 rounded-full text-sm font-medium transition"
          style="background: var(--color-primary); color: white;"
        >
          Ver proyectos
        </a>

        <a
          href="/contact"
          class="px-5 py-2 rounded-full text-sm font-medium border transition"
          style="border-color: var(--color-border);"
        >
          Hablemos
        </a>
      </div>

    </div>
  </Section>
</BaseLayout>