---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

const projects = [
  {
    slug: "elegants-inventory-sales",
    title: "Elegants",
    subtitle: "Sistema de inventario y ventas",
    role: "Full-stack · Deploy",
    description:
      "Sistema web para controlar inventario, ventas y reportes en tiempo real.",
    tech: ["Django", "PostgreSQL", "Tailwind"],
    cover: "/images/elegants1.jpg",
  },
];
---

<BaseLayout
  title="Projects · Pibadevs"
  description="Sistemas reales construidos para empresas reales."
>
  <Section title="Proyectos" eyebrow="Casos reales">
    
    <div class="flex flex-col divide-y" style="border-color: var(--color-divider);">

      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group grid md:grid-cols-[1.2fr_1fr] gap-8 py-10 reveal transition"
        >

          <!-- IMAGEN -->
          <div class="relative overflow-hidden rounded-xl">
            <img
              src={project.cover}
              alt={project.title}
              class="w-full h-full object-cover transition duration-500 group-hover:scale-[1.04]"
            />

            <div class="absolute inset-0"
                 style="background: linear-gradient(to top, rgba(0,0,0,.6), transparent);" />
          </div>

          <!-- CONTENIDO -->
          <div class="flex flex-col justify-center gap-3">

            <!-- TITULO -->
            <div>
              <h2 class="text-xl font-semibold group-hover:text-[var(--color-primary)] transition">
                {project.title}
              </h2>

              <p class="text-sm" style="color: var(--color-text-muted);">
                {project.subtitle}
              </p>
            </div>

            <!-- ROLE -->
            <span class="text-xs uppercase tracking-wide"
                  style="color: var(--color-primary);">
              {project.role}
            </span>

            <!-- DESC -->
            <p class="text-base max-w-md"
               style="color: var(--color-text-muted);">
              {project.description}
            </p>

            <!-- TECH -->
            <div class="flex flex-wrap gap-2 pt-2">
              {project.tech.map((t) => (
                <span class="text-xs px-2 py-1 rounded-full border"
                      style="border-color: var(--color-border);">
                  {t}
                </span>
              ))}
            </div>

            <!-- CTA -->
            <span class="text-sm mt-2 group-hover:text-[var(--color-primary)] transition">
              Ver caso completo →
            </span>

          </div>
        </a>
      ))}

    </div>

  </Section>
</BaseLayout>