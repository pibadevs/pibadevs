---
// src/pages/projects.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";

// src/pages/projects.astro
const projects = [
  {
    slug: "elegants-inventory-sales",
    title: "Elegants · Sistema de inventario y ventas",
    role: "Diseño, desarrollo full‑stack, despliegue",
    description:
      "Plataforma web para una tienda de ropa y accesorios que necesitaba dejar atrás Excel y llevar el control de inventario, ventas y reportes en un solo lugar.",
    tech: ["Django", "PostgreSQL", "Tailwind", "Chart.js"],
    cover: "/images/elegants1.jpg", // ← aquí
  },
];

---

<BaseLayout
  title="Projects · Pibadevs"
  description="Proyectos reales desarrollados por Pibadevs para PYMES y negocios en crecimiento."
>
  <Section title="Proyectos destacados" eyebrow="Projects">
    <div class="grid gap-4 md:grid-cols-2">
      {projects.map((project) => (
        <a
          href={`/projects/${project.slug}`}
          class="group flex flex-col overflow-hidden rounded-2xl border border-zinc-800 bg-zinc-900/40 hover:border-(--color-primary) hover:bg-zinc-900/70 transition-colors"
        >
          <div class="relative aspect-video overflow-hidden">
            <img
              src={project.cover}
              alt={project.title}
              loading="lazy"
              class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
            />
            <div class="pointer-events-none absolute inset-0 bg-linear-to-t from-zinc-950/70 via-zinc-950/10 to-transparent" />
          </div>
          <div class="flex flex-1 flex-col gap-2 px-4 pb-4 pt-3 text-sm text-zinc-300">
            <div>
              <h2 class="text-sm font-semibold text-zinc-50">
                {project.title}
              </h2>
              <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-(--color-tertiary)">
                {project.role}
              </p>
            </div>
            <p class="text-xs text-zinc-400 line-clamp-3">
              {project.description}
            </p>
            <div class="mt-2 flex flex-wrap gap-2">
              {project.tech.map((t) => (
                <span class="rounded-full bg-zinc-900 px-2 py-0.5 text-[10px] uppercase tracking-wide text-zinc-300">
                  {t}
                </span>
              ))}
            </div>
            <span class="mt-2 text-[11px] font-medium text-(--color-primary)">
              Ver detalles del proyecto →
            </span>
          </div>
        </a>
      ))}
    </div>
  </Section>
</BaseLayout>
