---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
import Section from "../../components/Section.astro";
import ElegantsGallery from "../../components/ElegantsGallery.astro";
---

<ProjectLayout
  pageTitle="Elegants · Sistema de inventario"
  pageDescription="Sistema de inventario y ventas desarrollado por Pibadevs."
  
  heroTitle="Elegants · Sistema de inventario"
  heroIntro="Sistema web que reemplazó Excel para controlar inventario, ventas y reservas en tiempo real."
  heroBody="Diseñado para una tienda en crecimiento, el sistema centraliza toda la operación en un solo lugar, con accesos por rol, métricas claras y trazabilidad completa."

  heroLeftBlocks={[
    {
      title: "Tipo de cliente",
      body: "Tienda física en crecimiento con operación basada en Excel y procesos manuales.",
    },
    {
      title: "Objetivo",
      body: "Centralizar inventario, ventas y reportes en un sistema único, claro y usable.",
    },
  ]}

  scopeTitle="Alcance del proyecto"
  scopeItems={[
    "Dashboard con métricas y alertas en tiempo real",
    "Gestión de productos con búsqueda instantánea",
    "Registro de ventas (contado y crédito)",
    "Historial completo de movimientos de inventario",
    "Reportes exportables en PDF y Excel",
    "Sistema de usuarios con roles definidos",
  ]}
  scopeNote="Desde el diseño de flujos hasta la implementación y adopción por parte del equipo."

  featuresTitle="Funcionalidades principales"
  features={[
    {
      title: "Dashboard",
      body: "Visualización clara de ventas, inventario y alertas clave para tomar decisiones rápidas.",
    },
    {
      title: "Inventario",
      body: "Gestión de productos con filtros rápidos y estado de stock en tiempo real.",
    },
    {
      title: "Ventas",
      body: "Flujo simple para registrar ventas y reservas sin fricción para el equipo.",
    },
  ]}

  tech={["Django", "Python", "PostgreSQL", "Tailwind CSS", "Chart.js"]}

  ctaTitle="¿Quieres un sistema así en tu empresa?"
  ctaEyebrow="Próximo paso"
  ctaBody="Podemos diseñar una solución similar adaptada a tu operación y necesidades reales."
  ctaHref="/contact"
  ctaLabel="Hablemos"
>
  <!-- GALERÍA -->
  <Section slot="gallery" title="Capturas del sistema" eyebrow="Producto">
    <ElegantsGallery client:load />
  </Section>
</ProjectLayout>