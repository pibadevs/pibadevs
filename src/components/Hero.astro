---
interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
}

const { title, subtitle, tagline } = Astro.props;
---

<section class="flex flex-col gap-8 py-2 sm:py-2">
  <div class="max-w-xl space-y-4">
    {
      tagline && (
        <p class="text-xs font-medium uppercase tracking-[0.2em] text-primary">
          {tagline}
        </p>
      )
    }
    <h1
      class="text-3xl font-semibold tracking-tight text-zinc-50 sm:text-4xl lg:text-5xl"
    >
      {title}
    </h1>
    {subtitle && <p class="text-sm text-zinc-400 sm:text-base">{subtitle}</p>}
    <div class="flex flex-wrap gap-3 pt-2 border:t border-primary">
      <a
        href="/projects"
        class="rounded-full border border-zinc-700 px-4 py-2 text-xs font-medium text-white hover:border-primary transition-colors"
      >
        Ver proyectos
      </a>
      <a
        href="/contact"
        class="rounded-full border border-zinc-700 px-4 py-2 text-xs font-medium text-white hover:border-primary transition-colors"
      >
        Hablemos
      </a>
    </div>
  </div>
</section>
