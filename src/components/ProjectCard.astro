---
interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
}

const { title, description, tech, link } = Astro.props;
---

<article class="flex flex-col gap-3 rounded-xl border border-zinc-800 bg-zinc-900/40 p-4 hover:border-red-500/70 transition-colors">
  <div>
    <h3 class="text-sm font-semibold text-zinc-50">{title}</h3>
    <p class="mt-1 text-xs text-zinc-400">
      {description}
    </p>
  </div>
  <div class="mt-auto flex flex-wrap gap-2">
    {tech.map((t) => (
      <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-[10px] uppercase tracking-wide text-zinc-300">
        {t}
      </span>
    ))}
  </div>
  {link && (
      <a href={link} class="mt-2 text-xs text-red-500 hover:text-red-500">
      Ver proyecto →
    </a>
  )}
</article>
